generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  password     String
  role         Role
  createdAt    DateTime  @default(now())
  otp          String?
  updatedAt    DateTime  @updatedAt
  isActive     Boolean   @default(true)
  otpExpiresAt DateTime?
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
}
