generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  password     String
  role         Role
  createdAt    DateTime  @default(now())
  otp          String?
  updatedAt    DateTime  @updatedAt
  isActive     Boolean   @default(true)
  otpExpiresAt DateTime?
  student      Student?
}

model Student {
  id            String   @id @default(uuid())
  name          String
  grade         Int
  email         String?
  phone         String?
  parentContact String?
  notes         String?
  userId        String?  @unique
  user          User?    @relation(fields: [userId], references: [id])

  marks         Mark[]
  receivedNotes Note[]
  quizAttempts  QuizAttempt[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Mark {
  id            String   @id @default(uuid())
  studentId     String
  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  grade         Int
  term          Int
  practicalMark Float?
  paperMark     Float?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([studentId, grade, term])
}

model Achievement {
  id          String   @id @default(uuid())
  title       String
  placement   String
  subtitle    String?
  year        Int
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GalleryItem {
  id        String          @id @default(uuid())
  title     String
  mediaType MediaType
  category  GalleryCategory
  url       String
  date      DateTime        @default(now())
  views     Int             @default(0)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model PastPaper {
  id          String   @id @default(uuid())
  title       String
  grade       Int
  term        Int?
  year        Int
  fileUrl     String
  uploadedAt  DateTime @default(now())
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

enum MediaType {
  PHOTO
  VIDEO
}

enum GalleryCategory {
  PERFORMANCES
  REHEARSALS
  AWARDS
  CULTURAL_EVENTS
}

model Note {
  id        String   @id @default(uuid())
  title     String
  content   String   @db.Text
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Announcement {
  id          String   @id @default(uuid())
  title       String
  description String   @db.Text
  grade       Int?     // If null, it's an overall announcement
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Quiz {
  id          String         @id @default(uuid())
  title       String
  description String?
  grade       Int
  startTime   DateTime
  endTime     DateTime
  duration    Int            // minutes allowed to complete
  isPublished Boolean        @default(false)
  questions   QuizQuestion[]
  attempts    QuizAttempt[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model QuizQuestion {
  id            String @id @default(uuid())
  quizId        String
  quiz          Quiz   @relation(fields: [quizId], references: [id], onDelete: Cascade)
  question      String @db.Text
  optionA       String
  optionB       String
  optionC       String
  optionD       String
  correctAnswer String // "A" | "B" | "C" | "D"
  orderIndex    Int
}

model QuizAttempt {
  id          String   @id @default(uuid())
  quizId      String
  quiz        Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  answers     Json     // { questionId: "A"|"B"|"C"|"D" }
  score       Float
  totalMarks  Int
  submittedAt DateTime @default(now())

  @@unique([quizId, studentId])
}
