# PostgreSQL connection string used by Prisma.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"

# Secret used to sign JWTs. Use a long random string in production.
JWT_SECRET="change-me-to-a-long-random-secret"

# Port the API listens on (defaults to 5000 if unset).
PORT=5000

# Gmail account used to send OTP / welcome emails.
# EMAIL_PASS must be a 16-character Google "App Password", not the account password.
EMAIL_USER="youraddress@gmail.com"
EMAIL_PASS="your-google-app-password"

# Optional: in production set this to your deployed frontend URL to restrict CORS.
# Leave unset locally to allow all origins.
# FRONTEND_URL="https://your-frontend.vercel.app"
